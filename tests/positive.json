      "action": "read",
      "fixture": "../fixtures/positive/basic.inc",
      "expect": {
        "metadata": {
          "title": {"type": "string", "value": "Basic data"},
          "version": {"type": "integer", "value": 1},
          "columns": {
            "score": {"type": "string", "value": "points"}
          }
        },
        "csv": {
          "columns": ["name", "score"],
          "rows": [["Ada", "21"], ["Babbage", "12"]]
        }
      }
    },
    {
      "id": "read-plain-csv",
      "action": "read",
      "fixture": "../fixtures/positive/plain.csv",
