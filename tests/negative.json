    {
      "id": "reject-invalid-key",
      "action": "read",
      "fixture": "../fixtures/negative/invalid_key.inc",
      "expect_error": {"error_code": "invalid_name"}
    },
    {
      "id": "reject-invalid-section-key",
      "action": "read",
      "fixture": "../fixtures/negative/invalid_section_key.inc",
      "expect_error": {"error_code": "invalid_name"}
    },
    {
      "id": "reject-repeated-key",
      "action": "read",
